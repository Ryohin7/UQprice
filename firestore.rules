rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 1. 商品資料庫 (products) 與 歷史價格 (product_prices)
    // ==========================================
    match /products/{productId} {
      // 任何造訪網站的使用者都可以讀取商品資料
      allow read: if true;
      // 拒絕任何人在前端直接新增、修改或刪除商品 (必須由後端爬蟲定時同步)
      allow write: if false;
    }
    
    match /product_prices/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // ==========================================
    // 2. 商品瀏覽量統計 (product_views)
    // ==========================================
    match /product_views/{productId} {
      allow read: if true;
      // 允許前端使用者增加瀏覽量計數 (即 update 動作，但限制只能累加 views 欄位)
      allow create, update: if request.resource.data.keys().hasOnly(['views']) 
                            || request.resource.data.views == resource.data.views + 1;
      // 拒絕前端使用者隨意刪除瀏覽量記錄
      allow delete: if false;
    }

    // ==========================================
    // 3. 系統版本歷史 (versions)
    // ==========================================
    match /versions/{versionId} {
      allow read: if true;
      // 拒絕未授權的前端寫入 (若未來有搭配 Firebase Auth 可改為 if request.auth != null)
      allow write: if false;
    }

    // ==========================================
    // 4. 前台導航選單 (navigation)
    // ==========================================
    match /navigation/{navigationId} {
      allow read: if true;
      // 拒絕未授權的前端寫入 (若未來有搭配 Firebase Auth 可改為 if request.auth != null)
      allow write: if false;
    }

    // ==========================================
    // 5. 系統與爬蟲狀態 (system / crawler_reports)
    // ==========================================
    match /system/{systemId} {
      allow read: if true;
      allow write: if false;
    }

    match /crawler_reports/{reportId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
